# =============================================================================
# Cobbli — frontend env (committed; safe values only)
# =============================================================================
# This file is checked into git. Only put values that are SAFE in a public
# client bundle (Vite inlines anything starting with VITE_ into the JS that
# ships to the browser). Server-side secrets go elsewhere — see the bottom of
# this file for a map.
# =============================================================================

# Supabase — publishable (anon) key is fine in client. Project owns auth/RLS.
VITE_SUPABASE_PROJECT_ID="vzyrzhfxdrtgyhpddvlj"
VITE_SUPABASE_URL="https://vzyrzhfxdrtgyhpddvlj.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_MP1CxrG_PdmfAKIIG_AaBw_odcAbC9m"
VITE_GA_MEASUREMENT_ID="G-3QRCC03ZRG"

# Stripe — publishable key is safe in client. The SECRET key is not.
# Get from Stripe Dashboard → Developers → API keys → "Publishable key".
# Use pk_test_* for preview deploys, pk_live_* for production.
VITE_STRIPE_PUBLISHABLE_KEY=""

# FastAPI backend URL — set this once the backend is deployed to Vercel.
# Frontend's apiFetch() helper reads this; leave empty to fall back to direct
# Supabase Edge Function invocations.
# Examples:
#   local dev   →  http://localhost:8000
#   preview     →  https://cobbli-api-<branch>.vercel.app
#   production  →  https://api.cobbli.com
VITE_API_URL=""


# =============================================================================
# Where the OTHER secrets live (do NOT add them here):
# =============================================================================
#
# Supabase Edge Function secrets
#   Set via:  supabase secrets set --project-ref vzyrzhfxdrtgyhpddvlj NAME=value
#   Or UI:    https://supabase.com/dashboard/project/vzyrzhfxdrtgyhpddvlj/functions/secrets
#   Required:
#     STRIPE_SECRET_KEY            (sk_test_* or sk_live_*)
#     STRIPE_WEBHOOK_SECRET        (whsec_*; from Stripe → Webhooks)
#     BREVO_API_KEY                (Brevo → SMTP & API → API Keys)
#     LOVABLE_API_KEY              (legacy AI gateway, used by analyze-shoe-photos)
#     SUPABASE_URL                 (auto-injected by Supabase, no action needed)
#     SUPABASE_SERVICE_ROLE_KEY    (auto-injected by Supabase, no action needed)
#
# FastAPI backend env (Vercel)
#   Set via:  cd backend && vercel env add NAME    (then paste value)
#   Or UI:    https://vercel.com/<team>/<project>/settings/environment-variables
#   Required (mirrors Edge Functions):
#     SUPABASE_URL                 https://vzyrzhfxdrtgyhpddvlj.supabase.co
#     SUPABASE_SERVICE_ROLE_KEY    (sb_secret_*; from Supabase → Settings → API → service_role)
#     STRIPE_SECRET_KEY
#     STRIPE_WEBHOOK_SECRET
#     BREVO_API_KEY
#     AI_API_KEY                   (replaces LOVABLE_API_KEY when migrated)
#     CORS_ALLOW_ORIGINS           comma-separated frontend URLs, or "*"
#
# Local dev secrets (per-developer, NEVER commit)
#   File:     .envrc.local         (gitignored)
#   Holds:    SUPABASE_ACCESS_TOKEN  (your sbp_* PAT, used by MCP + supabase CLI)
#             optionally local copies of any of the above for `uvicorn` runs
#   Load with:  source .envrc.local         (or use direnv to auto-load)
#
# Google OAuth (Supabase Auth → Providers → Google — UI only, not in any file)
#   Client ID + Client Secret from Google Cloud Console → Credentials.
#   Authorized redirect URI on Google's side: https://vzyrzhfxdrtgyhpddvlj.supabase.co/auth/v1/callback
# =============================================================================
