# Copy to .env.local and fill in. Do NOT commit real values.
# Lovable Cloud (Supabase) — auto-provisioned, normally already in .env
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Stripe publishable key (safe in client bundle). Server-side secret key
# (STRIPE_SECRET_KEY) and webhook signing secret (STRIPE_WEBHOOK_SECRET)
# are stored as edge-function secrets — not here.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Cal.com — NEVER commit real values.
# These are stored as Supabase edge-function secrets (not in this file):
#   CAL_API_KEY           – API key from cal.com → Settings → Security → API Keys
#   CAL_EVENT_TYPE_ID     – Numeric ID of the "Cobbli Pickup & Return" event type
#                           (visible in the URL when you open the event type in the
#                           Cal.com dashboard, or via GET /v2/event-types)
#
# To set them run:
#   supabase secrets set CAL_API_KEY=<your_key>
#   supabase secrets set CAL_EVENT_TYPE_ID=<numeric_id>

# Calendly — kept until the Cal.com migration is confirmed working end to end.
# NEVER commit real values. Stored as Supabase edge-function secrets:
#   CALENDLY_PAT             – Personal Access Token from calendly.com/integrations/api_webhooks
#   CALENDLY_EVENT_TYPE_URI  – e.g. https://api.calendly.com/event_types/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Pre-launch mode (2026-07-20). Set to "true" in the AWS hosting build
# environment to make EVERY route on cobbli.com show the ComingSoon
# waitlist page instead of the real site (not just "/" — see PreviewGate in
# src/App.tsx). To go live for everyone: set this to "false" (or delete it)
# and redeploy — no code change needed.
VITE_COMING_SOON=true

# Danielle's private bypass while VITE_COMING_SOON is on — visiting any URL
# with ?preview=<this value> unlocks the real site in that browser only
# (saved to localStorage). NEVER commit the real value used in production;
# treat it like a password. Generate a fresh random one, e.g.:
#   openssl rand -hex 12
VITE_PREVIEW_KEY=
