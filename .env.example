# Copy to .env.local and fill in. Do NOT commit real values.
# Lovable Cloud (Supabase) — auto-provisioned, normally already in .env
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Stripe publishable key (safe in client bundle). Server-side secret key
# (STRIPE_SECRET_KEY) and webhook signing secret (STRIPE_WEBHOOK_SECRET)
# are stored as edge-function secrets — not here.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
