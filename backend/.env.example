# Supabase (server-side; SERVICE_ROLE only here, never on the client)
SUPABASE_URL=https://vzyrzhfxdrtgyhpddvlj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Anon/publishable key — REQUIRED in prod. Used for the RLS-respecting,
# user-JWT-scoped client. If unset, the user client silently falls back to the
# service-role key and BYPASSES RLS on every /ops route.
SUPABASE_ANON_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Brevo transactional email
BREVO_API_KEY=

# AI provider (replaces LOVABLE_API_KEY when migrating analyze-shoe-photos)
AI_API_KEY=

# Comma-separated list of allowed origins; "*" if unset.
# Prod: lock to the SPA origin, e.g. https://cobbli.com
CORS_ALLOW_ORIGINS=http://localhost:5173

# Public site origin — builds password-recovery links in walk-up welcome email.
SITE_URL=https://cobbli.com
